{
  "build": {
    "distDir": "../../ui",
    "devPath": "../../ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "ScribeRx",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": false,
        "close": true,
        "show": true,
        "hide": true,
        "setAlwaysOnTop": true,
        "setPosition": true
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": false,
      "targets": "all",
      "identifier": "com.scriberx.app",
      "icon": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "ScribeRx",
        "width": 380,
        "height": 180,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "visible": false,
        "focus": false,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ]
  }
}
